# ============================================================
# RGM-INFRA — Variáveis de ambiente (copie para .env)
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=rgm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Porta do host para o PostgreSQL Docker (evita conflito com PostgreSQL local na 5432)
POSTGRES_PORT=5434

# ── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=images

# ── Backend ─────────────────────────────────────────────────
# JWT_SECRET é obrigatório em produção (mínimo 32 bytes).
# Em dev, o perfil 'dev' usa uma chave padrão automaticamente.
JWT_SECRET=

# CORS: origens permitidas separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api

# ── Imagens Docker (produção) ───────────────────────────────
BACKEND_IMAGE=rgm-backend:latest
FRONTEND_IMAGE=rgm-frontend:latest
