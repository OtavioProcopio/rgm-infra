# ============================================================
# RGM-INFRA — Variáveis de ambiente
# Copie para .env e ajuste conforme o ambiente.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=rgm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Porta exposta no host (evita conflito com PostgreSQL local na 5432)
POSTGRES_PORT=5434

# ── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=images

# ── JWT (obrigatório em produção — mínimo 32 caracteres) ────
JWT_SECRET=

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (dev) ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api

# ── Imagens Docker (produção) ───────────────────────────────
# Publicadas automaticamente pelo pipeline release (push de tag v*.*.*).
# Para build local: docker build -t rgm-backend:latest . (na raiz do repo)
BACKEND_IMAGE=ghcr.io/otavioprocopio/rgm-backend:latest
FRONTEND_IMAGE=ghcr.io/otavioprocopio/rgm-frontend:latest

# ── E2E (Playwright) ────────────────────────────────────────
E2E_ADMIN_EMAIL=admin@rgm.com
E2E_ADMIN_PASSWORD=admin123

# ── Monitoramento (Prometheus + Grafana) ────────────────────
GRAFANA_PASSWORD=admin
